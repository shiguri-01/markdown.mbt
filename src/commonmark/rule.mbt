///|
/// Returns the built-in CommonMark rule.
///
/// The rule registers block, inline, delimiter, and core entries under `cm:`
/// rule names.
pub fn rule() -> @markdown.Rule {
  @markdown.Rule("commonmark")
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:blank"),
      priority=100,
      blank_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:fenced_code"),
      priority=90,
      fenced_code_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:indented_code"),
      priority=80,
      indented_code_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:thematic_break"),
      priority=70,
      thematic_break_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:setext_heading"),
      priority=68,
      setext_heading_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:html"),
      priority=65,
      html_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:atx_heading"),
      priority=60,
      atx_heading_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:block_quote"),
      priority=50,
      blockquote_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:list"),
      priority=40,
      list_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:reference_definition"),
      priority=10,
      reference_definition_block,
    ),
  )
  .extend(
    @markdown.Rule::block(
      @markdown.RuleName::raw("cm:block:paragraph"),
      priority=0,
      paragraph_block,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:image"),
      priority=90,
      image_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:link"),
      priority=80,
      link_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:autolink"),
      priority=75,
      autolink_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:raw_html"),
      priority=74,
      raw_html_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:entity"),
      priority=73,
      entity_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:code_span"),
      priority=70,
      code_span_inline,
    ),
  )
  .extend(
    @markdown.Rule::delimiter(
      @markdown.RuleName::raw("cm:delimiter:emphasis"),
      priority=60,
      emphasis_delimiter,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:hard_break"),
      priority=45,
      hard_break_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:escape"),
      priority=40,
      escape_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:soft_break"),
      priority=20,
      soft_break_inline,
    ),
  )
  .extend(
    @markdown.Rule::inline(
      @markdown.RuleName::raw("cm:inline:text"),
      priority=-1000,
      text_inline,
    ),
  )
}
